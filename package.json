    "lucide-react": "^1.17.0",
    "next": "^16.2.1",
    "react": "19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
